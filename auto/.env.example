# --- Vercel API (도메인 연결·Edge Config 갱신) ---
VERCEL_TOKEN=
# 팀 프로젝트인 경우 (개인 계정이면 비워도 됨)
VERCEL_TEAM_ID=

# 태자 월드 프로덕션 Vercel 프로젝트 ID (대시보드 → Settings → General)
TAEJA_VERCEL_PROJECT_ID=

# (선택) Edge Config — 태자 월드 middleware와 동일 스토어 ID를 auto에서 PATCH
EDGE_CONFIG_ID=
# 태자 월드에 설정한 EDGE_CONFIG 과 동일 연결 문자열 (읽기는 태자 쪽, 쓰기는 토큰으로 API)

# --- 태자 월드 공개 URL (헬스 체크·이상 감지) ---
TAEJA_PUBLIC_URL=https://www.thaijaworld.com

# --- 이 배포의 공개 베이스 URL (루트 링크 웹 메타·canonical·/sitemap.xml). 미설정 시 VERCEL_URL·로컬 3010
# NEXT_PUBLIC_AUTO_SITE_URL=https://auto.example.com

# --- 크론·관리 API 인증 (Vercel Cron 은 Authorization: Bearer) ---
CRON_SECRET=
AUTO_ADMIN_SECRET=

# --- 선택: Postgres (Neon / Vercel Postgres). 없으면 인메모리 + 로컬 .data/state.json (개발만) ---
DATABASE_URL=

# --- 감시 정책 (선택) ---
AUTO_HEALTH_FAIL_THRESHOLD=3
AUTO_STANDBY_COOLDOWN_MS=3600000
AUTO_MAX_DOMAIN_SWITCHES_PER_DAY=5

# --- 관리자 봇 미디어 업로드 (Nord VPN 전용 IP 권장) ---
# POST /api/bot/ingest — Authorization: Bearer <INGEST_BOT_SECRET>
INGEST_BOT_SECRET=
# 콤마 구분. Nord 전용 IP를 넣으면 해당 IP에서만 Bearer 유효 (프로덕션 권장)
INGEST_IP_ALLOWLIST=
# 출처 URL 감사용(선택). 비우면 호스트 검증 생략. 예: cdn.example.com,*.trusted.org
INGEST_ALLOWED_SOURCE_HOSTS=
INGEST_MAX_BYTES=10485760
# 콤마 구분 MIME 화이트리스트
INGEST_ALLOWED_MIME=image/jpeg,image/png,image/webp,image/gif,image/avif,video/mp4,video/webm
# (선택) Vercel Blob — 없으면 수신·감사만 하고 저장 생략
BLOB_READ_WRITE_TOKEN=

# --- 로컬·숨김 우선 (외부로 운영 신호·강령을 안 보냄) ---
# 1이면 외부 AI 게이트웨이 호출 안 함 — 규칙 엔진만 사용
AUTO_PIPELINE_LOCAL_ONLY=0
LLANGKKA_PIPELINE_LOCAL_ONLY=0
# 강령 파일 (기본: 프로젝트 루트 PIPELINE_CHARTER.md)
LLANGKKA_CHARTER_PATH=
# 1일 때만 외부 브레인 프롬프트에 강령 일부 포함(기본 0 — 유출 주의)
AUTO_BRAIN_INCLUDE_CHARTER=0

# --- AI 두뇌 (Vercel AI Gateway — OpenAI 호환 베이스 URL) ---
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
# 게이트웨이에 등록된 강한 범용 모델 문자열 (예: openai/gpt-4o, anthropic/claude-3-5-sonnet-20241022)
AUTO_BRAIN_MODEL=openai/gpt-4o
AUTO_BRAIN_MIN_CONFIDENCE=0.72
AUTO_BRAIN_RETURN_NORMAL_MIN_CONFIDENCE=0.82

# --- 온체인 자동결제 (운영 핫 지갑 → 수취 주소, 네이티브 토큰) ---
# 1=켜짐. 파이프라인에서 standby/도메인 승격 시마다(쿨다운 내 1회) 송금 시도
AUTO_PAY_ENABLED=0
AUTO_PAY_SIGNER_PRIVATE_KEY=
AUTO_PAY_RECIPIENT=
AUTO_PAY_RPC_URL=
AUTO_PAY_CHAIN_ID=1
# wei 정수 문자열
AUTO_PAY_AMOUNT_WEI=0
AUTO_PAY_COOLDOWN_MS=300000
