# 태자 월드 (Taeja World) — 환경 변수 템플릿
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.
# .env.local 은 절대 Git에 커밋하지 마세요 (.gitignore 에 포함되어 있어야 함).
#
# ── 중앙 볼트 (선택) ───────────────────────────────────────────────────────
# 실제 값은 E:\01_Master_Keys\by-project\thai-ja-world.env 에만 두고,
# 개발할 때 필요한 줄만 여기(.env.local)로 복사해 쓰는 방식을 권장합니다.
# 볼트 사용법: E:\01_Master_Keys\HOW_TO_USE.md

# ── Supabase ──────────────────────────────────────────────────────────────
# Supabase 프로젝트 → Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# !! 서버 전용 — 절대 브라우저에 노출 금지 !!
# Supabase 프로젝트 → Settings → API → service_role 키
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── 봇 정책 ──────────────────────────────────────────────────────────────
# auto  = 인시던트 자동 처리 (heal 액션 dry-run 기록)
# manual = 사람 검토 대기 (skipped 기록 + Slack 알림)
# Phase 3 에서 bot_policies 테이블로 마이그레이션 예정
BOT_POLICY_MODE=manual

# ── 크론 정리(보관 일수) ───────────────────────────────────────────────────
# /api/cron/purge-bot-actions — 관리자 «봇 기록» 테이블(bot_actions) 오래된 행 삭제 (기본 7일)
# BOT_ACTIONS_RETENTION_DAYS=7
# /api/cron/purge-news — raw_news 오래된 행 (NEWS_RETENTION_DAYS, 기본 7일)
# NEWS_RETENTION_DAYS=7

# ── 관리자 화이트리스트 (운영 필수) ─────────────────────────────────────────
# 비어 있으면 «로그인만 하면 관리자»가 되어 위험합니다. 프로덕션에서는 반드시 지정하세요.
# ADMIN_ALLOWED_EMAILS=you@example.com,colleague@example.com

# ── Vercel Cron / 수동 봇 호출 ─────────────────────────────────────────────
# vercel.json 의 /api/cron/news 등과 동일 값. 미설정 시 로컬은 검증 생략, 프로덕션에서는 설정 권장.
# CRON_SECRET=<long-random-string>

# ── 뉴스 승인 큐 (기본 manual = 초안만 → /admin/news 에서 «홈에 게시») ───
# 즉시 공개가 필요할 때만: NEWS_PUBLISH_MODE=auto
# NEWS_PUBLISH_MODE=manual

# ── 뉴스 피드 수집 ────────────────────────────────────────────────────────
# 직접 RSS를 주면 Google 검색 대신 이 목록만 사용 (쉼표 구분)
# 예: https://news.google.com/rss?hl=ko&gl=TH&ceid=TH:ko
NEWS_RSS_URLS=
# NEWS_RSS_URLS 가 비어 있으면 Google News RSS 검색(아래 쿼리·지역)으로 피드 URL을 만듭니다.
# NEWS_GOOGLE_RSS_QUERIES=태국 살이,방콕 꿀팁,태국 비자
NEWS_GOOGLE_RSS_HL=ko
# 태국 대국 뉴스·정보 위주 (한국 중심이면 KR)
NEWS_GOOGLE_RSS_GL=TH
# 피드당 가져올 최대 항목 수 (1–50, 기본 8)
NEWS_ITEMS_PER_FEED=8
# 수집 기사를 Supabase news_sources / raw_news 에 저장 (schema_v2_fresh_start.sql 필요)
# 테이블이 아직 없거나 잠깐 끄려면 false
NEWS_PERSIST_TO_DB=true

# ── Slack 알림 (선택, 보안) ───────────────────────────────────────────────
# 설정 시 셀프힐링 인시던트 감지 시 알림 전송
# 반드시 https://hooks.slack.com/ 으로 시작해야 함 (SSRF 방지)
# 미설정 시 알림 없이 DB 로그만 기록
SLACK_WEBHOOK_URL=

# ── PC 상시 켜 두고 봇 크론 격발 ─────────────────────────────────────────
# npm run bot:knowledge:daemon        → Next 가 떠 있어야 함 (http://127.0.0.1:3000/api/cron/knowledge)
# npm run bot:knowledge:daemon:direct → Next 없이 동일 수집·가공 (Supabase·키만 있으면 됨)
# 프로덕션에서 돌리면 BOT_CRON_BASE_URL=https://thaijaworld.com + CRON_SECRET 동일 값
# BOT_CRON_BASE_URL=https://thaijaworld.com
# BOT_CRON_INTERVAL_MS=2700000
# BOT_KNOWLEDGE_IDEMPOTENCY=hour
# BOT_CRON_NEWS_INTERVAL_MS=7200000

# ── 지식 파이프라인 (npm run knowledge:ingest) ───────────────────────────
# KNOWLEDGE_TRUST_MODE=strict   # 기본: 신뢰 도메인만 (go.th, bangkokpost.com 등)
# KNOWLEDGE_RELEVANCE_MODE=loose  # 기본 strict=비자·생활·사건 위주, 정치 일반 헤드라인 제외
# KNOWLEDGE_AUTO_SEED=0         # 1회 스크립트에서 커리된 RSS·공식 URL 시드 끄기
# KNOWLEDGE_UPSERT_IGNORE_DUPLICATES=false  # 이미 있는 external_url 도 갱신(merge)

# ── 모더레이션 (게시판 이미지 업로드) ─────────────────────────────────────
# 운영에서는 OPENAI_API_KEY 설정을 권장합니다.
# 미설정 시 기본은 fail-open(이미지 검수 스킵 후 글 등록 허용)입니다.
OPENAI_API_KEY=
# 키 미설정일 때도 이미지 글 작성을 막고 싶으면 true/1
# REQUIRE_OPENAI_FOR_IMAGE_MODERATION=true

# ── 커뮤니티: 조회수 공개 (posts.view_count 는 그대로 저장·SELECT) ─────────
# 기본(미설정)=공개 UI 비활성 — 트래픽·조회수 증가 API 연결 후 true 로 켤 것
# NEXT_PUBLIC_COMMUNITY_PUBLIC_VIEW_COUNTS=true

# ── auto (taeja-auto) 공개 URL — /hub 리다이렉트·문서용. 로컬 기본 http://127.0.0.1:3010
# NEXT_PUBLIC_AUTO_PUBLIC_URL=https://auto.example.com

# ── Landing 3D (Spline) ────────────────────────────────────────────────────
# Spline에서 Publish/Share 후 받은 Embed URL 또는 scene URL을 넣으세요.
# 예: https://my.spline.design/xxxxx/ 또는 https://prod.spline.design/.../scene.splinecode
NEXT_PUBLIC_SPLINE_HERO_SCENE_URL=

# ── Landing Stats 노출 모드 ────────────────────────────────────────────────
# live    : 실데이터 그대로 노출
# curated : 실데이터 로직은 유지하되, 노출은 최소치 보정(+)으로 표시
NEXT_PUBLIC_LANDING_STATS_VISIBILITY_MODE=curated
NEXT_PUBLIC_LANDING_STATS_FLOOR_POST=120
NEXT_PUBLIC_LANDING_STATS_FLOOR_SPOT=30
NEXT_PUBLIC_LANDING_STATS_FLOOR_NEWS=180
NEXT_PUBLIC_LANDING_STATS_FLOOR_MEMBER=300
