    "@vercel/speed-insights": "^2.0.0",
    "next": "^15.5.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tsx": "^4.21.0",
    "undici": "^7.22.0",
    "web-push": "^3.6.7",
    "workflow": "^4.2.0-beta.72"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.3.1",
    "prisma": "^7.6.0",
    "shadcn": "^4.1.1",
    "typescript": "^5.7.0"
  }
