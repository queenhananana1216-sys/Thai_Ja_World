# 태자 월드 (Taeja World) — 환경 변수 템플릿
# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채우세요.
# .env.local 은 절대 Git에 커밋하지 마세요 (.gitignore 에 포함되어 있어야 함).
#
# ── 로컬에서 화면이 맨 텍스트·로딩만 멈출 때 ─────────────────────────────
# Cursor/VS Code 의 Console Ninja 확장이 Next 번들(bundle5.js)을 망가뜨릴 수 있음.
# package.json postinstall 이 훅을 제거합니다. 그래도 이상하면: dev 서버 중지 → .next 삭제
# → npm install → npm run dev / 또는 Console Ninja 비활성화.

# ── Supabase ──────────────────────────────────────────────────────────────
# Supabase 프로젝트 → Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Authentication → Providers → Email
# 프로덕션: "Confirm email" 켜면 가입 후 /auth/check-email 안내 → 메일 링크 → /auth/callback
# 개발만: Confirm email 끄면 가입 직후 바로 로그인(이메일 단계 생략)

# !! 서버 전용 — 절대 브라우저에 노출 금지 !!
# Supabase 프로젝트 → Settings → API → service_role 키
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Supabase SQL: supabase/migrations/010_profiles_last_seen_admin.sql — 이용자 마지막 접속·관리자 정렬
#
# 선택: /admin 접근을 특정 로그인 이메일로만 제한 (쉼표·공백 구분, 소문자 무시)
# 비우면 «로그인만» 되면 관리자 메뉴에 들어갈 수 있음(소규모·개발용).
# 비밀번호는 Gmail이 아니라 이 사이트(Supabase) 가입 시 설정한 비밀번호입니다.
ADMIN_ALLOWED_EMAILS=

# Authentication → URL Configuration → Redirect URLs 예시:
#   http://127.0.0.1:3000/auth/callback
#   http://127.0.0.1:3000/auth/reset
#   https://thaijaworld.com/auth/callback
#   https://thaijaworld.com/auth/reset
# /auth/check-email 은 Redirect 목록에 넣지 않아도 됨(앱 내 안내 페이지).

# ── 로그인·가입 보강 (선택, 무료) — Cloudflare Turnstile ─────────────────
# [확인·발급 순서]
# 1) https://dash.cloudflare.com 로그인 (무료 계정 가능)
# 2) 왼쪽 또는 상단에서 Turnstile(턴스타일) 메뉴로 이동
# 3) "Add widget" / 위젯 추가 → 이름 임의(예: taeja-login)
# 4) Widget mode: 보통 "Managed" 추천
# 5) Hostnames: 로컬 개발용으로 아래를 포함 (없으면 localhost 에서 안 돌아감)
#      · localhost
#      · 127.0.0.1
#    배포 시: thaijaworld.com / www.… 등 실제 도메인도 추가
# 6) 생성 후 화면에 나오는 값 복사:
#      · Site Key  → NEXT_PUBLIC_TURNSTILE_SITE_KEY  (공개돼도 됨, 프론트용)
#      · Secret Key → TURNSTILE_SECRET_KEY           (서버만, 절대 깃·채팅 금지)
# 7) .env.local 저장 후 dev 서버 재시작 (npm run dev)
# 미입력 시: 가입/로그인 화면에서 Turnstile 위젯이 안 뜨고, 검증 API는 통과 처리됨.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google: Supabase Provider + NEXT_PUBLIC_AUTH_GOOGLE=1 (미설정 시 프로덕션 UI에 버튼 없음)
NEXT_PUBLIC_AUTH_GOOGLE=

# ── 봇 정책 ──────────────────────────────────────────────────────────────
# auto  = 인시던트 자동 처리 (heal 액션 dry-run 기록)
# manual = 사람 검토 대기 (skipped 기록 + Slack 알림)
# Phase 3 에서 bot_policies 테이블로 마이그레이션 예정
BOT_POLICY_MODE=manual

# ── 뉴스 자동 파이프라인 (수집 → 한글 요약·번역) ─────────────────────────
# 1) NEWS_RSS_URLS + OPENAI_API_KEY + Supabase service role (위 참고)
# 2) 배포 후 Vercel → Settings → Cron Jobs 에서 /api/cron/news 확인
# 3) CRON_SECRET 설정 시: Vercel이 Cron 요청에 Bearer 로 넣어 줌. 수동 호출도 동일 값 사용.
#    POST https://<도메인>/api/bot/news-pipeline  Header: Authorization: Bearer <CRON_SECRET>
#    기존 기사에 태국어(th) 없을 때: POST /api/bot/backfill-bilingual-news  (동일 Bearer, body 선택)
# 4) /api/cron/purge-news — NEWS_RETENTION_DAYS(기본 7) 지난 raw_news 삭제 → 홈이 오래된 글로 죽어 보이지 않게
CRON_SECRET=
# BOT_CRON_SECRET=   # 선택: CRON_SECRET 대신 써도 됨 (둘 중 하나만 있으면 검증에 사용)

# ── 뉴스 피드 수집 (NEWS_RSS_URLS 설정 시 /api/bot/collect 사용) ─────────
# 예: https://news.google.com/rss?hl=ko&gl=KR&ceid=KR:ko
NEWS_RSS_URLS=
# auto(기본)=LLM 후 바로 홈 노출 · manual=초안만 저장 → /admin/news 에서 «홈에 게시»
NEWS_PUBLISH_MODE=auto
# 피드당 가져올 최대 항목 수 (1–50, 기본 8)
NEWS_ITEMS_PER_FEED=8
# 수집 기사를 Supabase news_sources / raw_news 에 저장 (schema_v2_fresh_start.sql 필요)
# 테이블이 아직 없거나 잠깐 끄려면 false
NEWS_PERSIST_TO_DB=true
# 홈·/news 상세 댓글: supabase/migrations/007_news_comments.sql 적용 필요
# 오래된 피드 정리(일)
NEWS_RETENTION_DAYS=7

# ── 뉴스 요약·번역 (POST /api/bot/process-news) ───────────────────────────
# OpenAI API 키 — 없으면 해당 API는 503 + bot_actions skipped
OPENAI_API_KEY=
# 선택: 기본 gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# 게시·댓글 자동 검열 모델 (선택, 기본 omni-moderation-latest)
OPENAI_MODERATION_MODEL=
# 한 번 호출에 처리할 미가공 기사 수 (1–30, 라우트 body.limit 이 우선)
NEWS_SUMMARIZE_BATCH_SIZE=8

# ── 익명/비공개 제보 — 메신저 링크 (클라이언트 노출 OK) ─────────────────────
# 예: https://t.me/your_bot, https://wa.me/66xxxxxxxx, https://line.me/ti/g/xxx
NEXT_PUBLIC_TIP_TELEGRAM_URL=
NEXT_PUBLIC_TIP_WHATSAPP_URL=
NEXT_PUBLIC_TIP_LINE_URL=

# ── 일일 뉴스 웹 푸시 (선택) ─────────────────────────────────────────────
# 터미널: npx web-push generate-vapid-keys
# 공개 키는 클라이언트에 노출됨. 비밀 키는 서버 전용.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID subscriber (mailto: 또는 https:)
VAPID_CONTACT_EMAIL=mailto:hello@thaijaworld.com
# 푸시 본문 링크용 절대 origin (미설정 시 VERCEL_URL 사용)
NEXT_PUBLIC_SITE_URL=https://thaijaworld.com

# ── Slack 알림 (선택, 보안) ───────────────────────────────────────────────
# 설정 시 셀프힐링 인시던트 감지 시 알림 전송
# 반드시 https://hooks.slack.com/ 으로 시작해야 함 (SSRF 방지)
# 미설정 시 알림 없이 DB 로그만 기록
SLACK_WEBHOOK_URL=

# ── 게시·댓글 모더레이션 (선택, 숫자만; 비우면 코드 기본값) ────────────────
# MODERATION_SCAM_BAN_HOURS=72
# MODERATION_STRIKE_THRESHOLD=3
# MODERATION_STRIKEOUT_BAN_HOURS=168
