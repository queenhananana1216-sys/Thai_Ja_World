{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "langka | {{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "diamond",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b0",
          "background": "#7C3AED",
          "foreground": "#F5F3FF",
          "template": " \uf120 langka "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#2563EB",
          "foreground": "#EFF6FF",
          "properties": {
            "style": "agnoster",
            "max_depth": 4,
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "\uf015",
            "folder_icon": "\uf07b"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "background": "#059669",
          "foreground": "#ECFDF5",
          "properties": {
            "fetch_status": true,
            "display_stash_count": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#94A3B8",
          "background": "transparent",
          "properties": {
            "threshold": 500,
            "style": "round"
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "#94A3B8",
          "background": "transparent",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#A78BFA",
          "template": "\u276f "
        }
      ]
    }
  ]
}
