{
  "name": "taeja-world",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/strip-console-ninja-next-hook.js",
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:turbo": "next dev --turbo --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "news:ingest": "tsx scripts/run-news-ingest-once.ts",
    "knowledge:ingest": "tsx scripts/run-knowledge-ingest-once.ts",
    "knowledge:reprocess-drafts": "tsx scripts/run-knowledge-reprocess-all-drafts.ts",
    "news:backfill-editor-notes": "tsx scripts/run-backfill-editor-notes-once.ts",
    "bot:knowledge:daemon": "node scripts/run-knowledge-cron-daemon.mjs",
    "bot:knowledge:daemon:direct": "tsx scripts/run-knowledge-daemon-direct.ts"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.100.1",
